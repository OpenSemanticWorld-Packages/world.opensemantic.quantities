    ],
    "description": [
        {
            "text": "The $litre$ (American spelling: $\\textit{liter}$; SI symbol $l$ or $L$) is a non-SI metric system unit of volume equal to $1 \\textit{cubic decimetre}$ ($dm^3$), 1,000 cubic centimetres ($cm^3$) or $1/1000 \\textit{cubic metre}$. If the lower case \"L\" is used as the symbol, it is sometimes rendered as a cursive \"l\" to help distinguish it from the capital \"I\", although this usage has no official approval by any international bureau.",
            "lang": "en"
        }
    ],
